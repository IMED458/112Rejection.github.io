# Google AI Studio (Gemini) API Key — required for AI features
# AI Studio automatically injects this from the Secrets panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (injected automatically by AI Studio).
APP_URL="MY_APP_URL"

# Firebase Admin SDK Service Account JSON (single-line stringified JSON)
# 1. Firebase Console → Project Settings → Service Accounts → Generate new private key
# 2. Paste the full JSON content as one line here (or set GOOGLE_APPLICATION_CREDENTIALS path)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"rejection-f96c5",...}'

# Server port (optional, defaults to 3000)
PORT=3000
